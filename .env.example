DATABASE_URL="postgresql://sots:password@localhost:5433/sots?connection_limit=3"

KAFKA_BROKERS="localhost:9092"

CLICKHOUSE_HOST="http://localhost:8123"
CLICKHOUSE_DATABASE="sots"
CLICKHOUSE_USER="sots"
CLICKHOUSE_PASSWORD="password"

JWT_SECRET="replace-with-a-secure-random-secret"
NODE_ENV="development"

# Email delivery. Without RESEND_API_KEY the email package records a skipped
# delivery and logs the rendered message for local development.
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""
EMAIL_SEND_DISABLED="false"
EMAIL_FROM_HELLO="Tellann <hello@tellann.co>"
EMAIL_FROM_SECURITY="Tellann Security <security@tellann.co>"
EMAIL_FROM_REPORTS="Tellann Reports <reports@tellann.co>"
EMAIL_FROM_ALERTS="Tellann Alerts <alerts@tellann.co>"
EMAIL_FROM_BILLING="Tellann Billing <billing@tellann.co>"
EMAIL_FROM_SUPPORT="Tellann Support <support@tellann.co>"

# Experimental flow intelligence / AI-assisted declaration
# Keep these disabled for public/local MVP flows unless you are explicitly
# testing AI draft generation or contextual suggestions.
AI_FEATURES_ENABLED="false"
AI_FLOW_GENERATION_ENABLED="false"
AI_FLOW_SUGGESTIONS_ENABLED="false"

# Local/dev bypass for organization-level experimental AI entitlement checks.
# Keep false in shared, staging, and production environments.
AI_ALLOW_WITHOUT_ORG_ENTITLEMENT="false"

# Provider selection. "mock" uses deterministic local rule-based output and
# does not call an external provider. Set to "gemini" or "deepseek" with keys.
AI_PROVIDER="mock"

GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_API_URL="https://generativelanguage.googleapis.com/v1beta/openai/chat/completions"

DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_API_URL="https://api.deepseek.com/chat/completions"

# AI privacy/logging policy defaults. Raw prompts/output should stay disabled
# unless you are debugging locally with sanitized input.
AI_LOG_PROMPTS="false"
AI_STORE_RAW_OUTPUT="false"
AI_REDACT_INPUTS="true"

# Public web boundary
NEXT_PUBLIC_SITE_URL="http://localhost:3020"
NEXT_PUBLIC_MARKETING_URL="http://localhost:3020"
NEXT_PUBLIC_APP_URL="http://localhost:3010"
NEXT_PUBLIC_DOCS_URL="http://localhost:3021"
NEXT_PUBLIC_API_GATEWAY_URL="http://localhost:3000"
API_GATEWAY_INTERNAL_URL="http://localhost:3000"

# Production cookie scoping for the authenticated app subdomain.
# Leave empty for localhost development.
AUTH_COOKIE_DOMAIN=""

# CORS/origin hints for deployed services.
APP_ORIGIN="https://app.domain-name.com"
MARKETING_ORIGIN="https://domain-name.com"
DOCS_ORIGIN="https://docs.domain-name.com"
CORS_ALLOWED_ORIGINS="https://app.domain-name.com"

# Service ports
API_GATEWAY_PORT="3000"
EVENT_COLLECTOR_PORT="3001"
GRAPH_ENGINE_PORT="3002"
COVERAGE_ENGINE_PORT="3003"
REPORT_ENGINE_PORT="3004"
DEMONSTRATION_API_PORT="3005"
ONBOARDING_API_PORT="3006"
ENDPOINT_ENGINE_PORT="3007"
FDRS_API_PORT="3008"
BILLING_API_PORT="3009"
USAGE_TRACKER_PORT="3012"
AUTH_API_PORT="3013"

# Background workers admin (Bull Board job monitoring UI)
NEXT_PUBLIC_WORKERS_URL="http://localhost:3020"

# Billing provider placeholders for MVP wiring.
# The billing API supports MOCK checkout/webhooks without these values.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_SUCCESS_URL="https://app.sots.io/settings/billing?success=1"
STRIPE_CANCEL_URL="https://app.sots.io/settings/billing?cancelled=1"
PAYSTACK_SECRET_KEY=""
PAYSTACK_WEBHOOK_SECRET=""
PAYSTACK_SUCCESS_URL="https://app.sots.io/settings/billing?success=1"

# Kafka / ClickHouse feature flags.
# Set KAFKA_ENABLED=false to keep writing events directly to Postgres (dev default).
# Set CLICKHOUSE_ENABLED=false to keep analytics queries running against Postgres.
KAFKA_ENABLED="false"
CLICKHOUSE_ENABLED="false"

# System admin bootstrap.
# Set to the email address of the first system admin. The auth service will
# automatically grant DB-backed SystemAdmin on first login if not already present.
# This replaces the old SYSTEM_ADMIN_USER_IDS approach.
SYSTEM_ADMIN_BOOTSTRAP_EMAIL=""

# ─── Gap 1: Redis (optional — falls back to in-memory cache if not set) ───────
# Set this in staging/production for distributed ruleset caching across
# multiple service instances. Leave blank for local single-process development.
REDIS_URL=""

# ─── Gap 5: MFA — TOTP Secret Encryption ────────────────────────────────────
# AES-256 key used to encrypt TOTP secrets at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes). Required when MFA is enabled.
MFA_ENCRYPTION_KEY=""

# ─── Gap 6: SSO / OIDC ────────────────────────────────────────────────────────
# AES-256 key used to encrypt OIDC client secrets stored in the database.
# Generate the same way as MFA_ENCRYPTION_KEY above.
OIDC_CLIENT_SECRET_KEY=""
# Base URL used when constructing OIDC redirect URIs (callback URLs).
# Must match the registered redirect URI in your IdP application.
OIDC_REDIRECT_BASE_URL="http://localhost:3013"

# ─── Gap 8: Observability ─────────────────────────────────────────────────────
# Port for the /metrics endpoint on the background-workers service.
BACKGROUND_WORKERS_METRICS_PORT="3020"

# ─── OpenTelemetry Distributed Tracing ────────────────────────────────────────
# Set OTEL_TRACES_ENABLED=true to activate distributed tracing (requires Jaeger/Tempo).
OTEL_TRACES_ENABLED="false"
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
# OTEL_SERVICE_NAME is auto-detected from service name; override if needed.
