DATABASE_URL="postgresql://sots:password@localhost:5433/sots"

KAFKA_BROKERS="localhost:9092"

CLICKHOUSE_HOST="http://localhost:8123"
CLICKHOUSE_DATABASE="sots"
CLICKHOUSE_USER="sots"
CLICKHOUSE_PASSWORD="password"

JWT_SECRET="replace-with-a-secure-random-secret"
NODE_ENV="development"

# Public web boundary
NEXT_PUBLIC_SITE_URL="https://domain-name.com"
NEXT_PUBLIC_MARKETING_URL="https://domain-name.com"
NEXT_PUBLIC_APP_URL="https://app.domain-name.com"
NEXT_PUBLIC_DOCS_URL="https://docs.domain-name.com"
NEXT_PUBLIC_API_GATEWAY_URL="http://localhost:3000"
API_GATEWAY_INTERNAL_URL="http://localhost:3000"

# Production cookie scoping for the authenticated app subdomain.
# Leave empty for localhost development.
AUTH_COOKIE_DOMAIN=""

# CORS/origin hints for deployed services.
APP_ORIGIN="https://app.domain-name.com"
MARKETING_ORIGIN="https://domain-name.com"
DOCS_ORIGIN="https://docs.domain-name.com"
CORS_ALLOWED_ORIGINS="https://app.domain-name.com"

# Service ports
API_GATEWAY_PORT="3000"
EVENT_COLLECTOR_PORT="3001"
GRAPH_ENGINE_PORT="3002"
COVERAGE_ENGINE_PORT="3003"
REPORT_ENGINE_PORT="3004"
DEMONSTRATION_API_PORT="3005"
ONBOARDING_API_PORT="3006"
ENDPOINT_ENGINE_PORT="3007"
FDRS_API_PORT="3008"
BILLING_API_PORT="3009"
USAGE_TRACKER_PORT="3012"
AUTH_API_PORT="3013"

# Billing provider placeholders for MVP wiring.
# The billing API supports MOCK checkout/webhooks without these values.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
PAYSTACK_SECRET_KEY=""
PAYSTACK_WEBHOOK_SECRET=""
