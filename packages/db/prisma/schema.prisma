datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Organization {
  id                        String                     @id @default(uuid())
  name                      String
  slug                      String                     @unique
  createdByUserId           String?
  createdAt                 DateTime                   @default(now())

  // ─── Gap 4: Cross-tenant pattern matching ───────────────────────────────
  // Opted IN by default — org contributes anonymized state patterns to the
  // shared cross-tenant index. Org admins can disable this in settings.
  allowCrossTenantPatterns  Boolean                    @default(true)

  // ─── Gap 5: MFA enforcement ─────────────────────────────────────────────
  // When true, OWNER/ADMIN members must have TOTP enabled to access the dashboard.
  mfaRequiredForAdmins      Boolean                    @default(false)

  memberships               OrganizationMembership[]
  invitations               OrganizationInvitation[]
  applications              Application[]
  intentNormalizations      IntentNormalizationEntry[]
  subscription              Subscription?
  entitlement               Entitlement?
  notificationPreferences   NotificationPreference[]
  notificationEvents        NotificationEvent[]
  oidcProvider              OIDCProvider?
}

enum RulesetScope {
  GLOBAL
  ORGANIZATION
  APPLICATION
}

enum RulesetStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum RulesetVersionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum RulePatternType {
  DOMAIN_INFERENCE
  STATE_EXPECTATION
  TRANSITION_EXPECTATION
  MISSING_STATE
  MISSING_FLOW
  EDGE_CASE
  VALIDATION_CONSTRAINT
  RECOVERY_FLOW
}

enum RuleTriggerType {
  KEYWORD
  ROUTE_PATTERN
  API_PATTERN
  EVENT_TYPE
  STATE_NAME
  COMPONENT_NAME
  WORKFLOW_NAME
}

enum RuleSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum RuleSource {
  SYSTEM
  ADMIN
  USER_FEEDBACK
  AI_CANDIDATE
  OBSERVED_BEHAVIOR
}

enum AIFlowDraftSource {
  ONBOARDING_PROMPT
  FLOW_BUILDER
  ADMIN_TEST
}

enum AIFlowDraftStatus {
  PENDING_REVIEW
  ACCEPTED
  PARTIALLY_ACCEPTED
  REJECTED
  EXPIRED
}

enum SuggestionType {
  PREREQUISITE
  IN_STATE_VALIDATION
  POST_REQUISITE
  ERROR_PATH
  EMPTY_STATE
  LOADING_STATE
  RECOVERY_PATH
  SECURITY_STATE
  BUSINESS_RULE
}

enum SuggestionSource {
  RULE_ENGINE
  AI
  HYBRID
}

enum RuleFeedbackType {
  ACCEPTED
  REJECTED
  EDITED
  DISMISSED
  PROMOTED
}

enum RuleCandidateSource {
  AI
  USER_FEEDBACK
  OBSERVED_FLOW_VARIATION
  ADMIN_CREATED
}

enum RuleCandidateStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  PROMOTED
  MERGED
}

enum AIFeature {
  FLOW_GENERATION
  FLOW_SUGGESTION
  DOMAIN_INFERENCE
  OUTPUT_REPAIR
}

enum AIInvocationStatus {
  SUCCESS
  FAILED
  VALIDATION_FAILED
  TIMEOUT
  RATE_LIMITED
  DEGRADED
  FALLBACK_USED
  BLOCKED_BY_POLICY
}

model Domain {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(true)
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rulesets    DomainRuleset[]
}

model DomainRuleset {
  id             String        @id @default(uuid())
  domainId       String
  key            String
  name           String
  description    String?
  scope          RulesetScope  @default(GLOBAL)
  status         RulesetStatus @default(ACTIVE)
  priority       Int           @default(100)

  organizationId String?
  applicationId  String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  domain         Domain @relation(fields: [domainId], references: [id])
  versions       DomainRulesetVersion[]

  @@unique([domainId, key, organizationId, applicationId])
  @@index([domainId, status])
  @@index([organizationId])
  @@index([applicationId])
}

model DomainRulesetVersion {
  id          String               @id @default(uuid())
  rulesetId   String
  version     Int
  status      RulesetVersionStatus @default(DRAFT)
  changelog   String?
  metadata    Json?

  createdBy   String?
  promotedBy  String?
  promotedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ruleset       DomainRuleset @relation(fields: [rulesetId], references: [id])
  patterns      RulePattern[]
  flowTemplates FlowTemplate[]

  @@unique([rulesetId, version])
  @@index([rulesetId, status])
}

model RulePattern {
  id               String          @id @default(uuid())
  rulesetVersionId String
  key              String
  name             String
  description      String?
  patternType      RulePatternType
  severity         RuleSeverity    @default(INFO)
  matcherJson      Json
  outputJson       Json
  confidenceBase   Float           @default(0.7)
  source           RuleSource      @default(SYSTEM)
  isActive         Boolean         @default(true)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  rulesetVersion   DomainRulesetVersion @relation(fields: [rulesetVersionId], references: [id])
  triggers         RuleTrigger[]

  @@index([rulesetVersionId, patternType])
  @@index([source])
}

model RuleTrigger {
  id            String          @id @default(uuid())
  rulePatternId String
  triggerType   RuleTriggerType
  value         String
  weight        Float           @default(1.0)
  createdAt     DateTime        @default(now())

  rulePattern   RulePattern @relation(fields: [rulePatternId], references: [id])

  @@index([triggerType, value])
  @@index([rulePatternId])
}

model FlowTemplate {
  id                 String  @id @default(uuid())
  rulesetVersionId   String
  key                String
  name               String
  description        String?
  workflowType       String
  statesJson         Json
  transitionsJson    Json
  edgeCasesJson      Json
  requiredEventsJson Json?
  metadata           Json?
  confidenceBase     Float   @default(0.75)
  isActive           Boolean @default(true)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  rulesetVersion     DomainRulesetVersion @relation(fields: [rulesetVersionId], references: [id])

  @@index([rulesetVersionId])
  @@index([workflowType])
}

model AIFlowDraft {
  id                      String            @id @default(uuid())
  organizationId          String
  applicationId           String
  environmentId           String?
  source                  AIFlowDraftSource
  status                  AIFlowDraftStatus @default(PENDING_REVIEW)
  /// Stores only the sanitized/redacted description — never raw user input
  productDescription      String?
  /// SHA-256 of the original raw description for audit deduplication (raw text never stored)
  productDescriptionHash  String?
  inferredDomainKey       String?
  rulesetVersionIds       String[]          @default([])
  promptHash              String
  provider                String
  model                   String
  aiInvocationId          String?
  draftJson               Json
  validationJson          Json?
  confidence              Float             @default(0.0)
  createdBy               String?
  reviewedBy              String?
  reviewedAt              DateTime?
  rejectionReason         String?

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([organizationId, applicationId])
  @@index([status])
  @@index([inferredDomainKey])
}

// =============================================================================
// AI FLOW DRAFT ASYNC JOB QUEUE (Gap 8 — non-blocking async generation)
// =============================================================================

enum AIFlowDraftJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model AIFlowDraftJob {
  id                  String               @id @default(uuid())
  organizationId      String
  applicationId       String
  environmentId       String?
  source              AIFlowDraftSource
  /// Already-sanitized description; raw text is never stored
  productDescription  String
  domainKey           String
  rulesetVersionIds   String[]             @default([])
  status              AIFlowDraftJobStatus @default(QUEUED)
  /// Populated when status = COMPLETED
  draftId             String?
  errorMessage        String?
  attempts            Int                  @default(0)
  maxAttempts         Int                  @default(3)
  scheduledAt         DateTime             @default(now())
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([status, scheduledAt])
  @@index([organizationId, applicationId])
}

model RuleFeedback {
  id              String           @id @default(uuid())
  organizationId  String
  applicationId   String?
  rulePatternId   String?
  suggestionId    String?
  aiFlowDraftId   String?
  feedbackType    RuleFeedbackType
  beforeJson      Json?
  afterJson       Json?
  comment         String?
  createdBy       String?
  createdAt       DateTime         @default(now())

  @@index([organizationId, applicationId])
  @@index([rulePatternId])
  @@index([suggestionId])
  @@index([aiFlowDraftId])
}

model RuleCandidate {
  id                     String              @id @default(uuid())
  domainId               String?
  organizationId         String?
  applicationId          String?
  source                 RuleCandidateSource
  status                 RuleCandidateStatus @default(PENDING_REVIEW)
  candidateJson          Json
  evidenceJson           Json?
  confidence             Float               @default(0.0)
  promotedRulePatternId  String?
  reviewedBy             String?
  reviewedAt             DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  @@index([domainId])
  @@index([status])
  @@index([source])
}

model AIInvocationLog {
  id                String             @id @default(uuid())
  organizationId    String
  applicationId     String?
  userId            String?
  feature           AIFeature
  provider          String
  model             String
  promptHash        String
  promptVersion     String?
  inputSummaryJson  Json?
  outputSummaryJson Json?
  status            AIInvocationStatus
  errorCode         String?
  errorMessage      String?
  errorMessageSafe  String?
  inputTokens       Int?
  outputTokens      Int?
  totalTokens       Int?
  latencyMs         Int?
  costEstimate      Decimal?
  repaired          Boolean @default(false)
  fallbackUsed      Boolean @default(false)
  createdBy         String?
  createdAt         DateTime           @default(now())

  @@index([organizationId, applicationId])
  @@index([feature])
  @@index([provider, model])
  @@index([status])
}

// =============================================================================
// PRICING & ENTITLEMENTS (Phase 1.8A)
// =============================================================================

enum PlanType {
  FREE
  LOCAL       // Nigeria-only
  SOLO
  TEAM
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  GRACE_PERIOD
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

enum BillingCurrency {
  USD
  NGN
}

model Plan {
  id              String   @id @default(uuid())
  type            PlanType @unique
  name            String
  description     String?
  monthlyPriceUsd Int?     // Price in cents (2900 = $29)
  monthlyPriceNgn Int?     // Price in kobo (4200000 = ₦42,000)
  annualPriceUsd  Int?     // Price in cents
  annualPriceNgn  Int?     // Price in kobo
  isPublic        Boolean  @default(true)
  sortOrder       Int      @default(0)

  // Resource limits
  maxApplications Int
  maxEnvironmentsPerApp Int @default(1)
  maxApiKeys      Int @default(1)
  maxUsers        Int
  maxStorageGb    Int
  retentionDays   Int
  maxDemoSessions Int?     // null = unlimited

  featureFlags  FeatureFlag[]
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeatureFlag {
  id      String  @id @default(uuid())
  planId  String
  plan    Plan    @relation(fields: [planId], references: [id])
  feature String  // e.g. "SESSION_REPLAY", "API_ACCESS", "SSO"
  enabled Boolean @default(false)
  tier    String? // e.g. "BASIC", "ADVANCED", "ALL_FORMATS"

  createdAt DateTime @default(now())

  @@unique([planId, feature])
}

model Subscription {
  id                       String             @id @default(uuid())
  organizationId           String             @unique
  organization             Organization       @relation(fields: [organizationId], references: [id])
  planId                   String
  plan                     Plan               @relation(fields: [planId], references: [id])
  status                   SubscriptionStatus @default(ACTIVE)
  billingInterval          BillingInterval    @default(MONTHLY)
  billingCurrency          BillingCurrency    @default(USD)

  // Stripe references (Phase 1.8C)
  stripeCustomerId         String?
  stripeSubscriptionId     String?

  // Paystack references (Phase 1.8C)
  paystackCustomerCode     String?
  paystackSubscriptionCode String?

  // Enterprise overrides (JSON: { maxApplications: 200, ... })
  enterpriseOverrides Json?

  trialEndsAt        DateTime?
  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  suspendedAt        DateTime?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  usageRecords UsageRecord[]
}

model Entitlement {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Resolved entitlements (denormalized from plan + enterprise overrides)
  planType PlanType
  features Json // { sessionReplay: true, apiAccess: false, ... }
  limits   Json // { applications: 10, users: 10, storageGb: 100, ... }
  support  Json // { emailSupport: true, prioritySupport: false, ... }

  resolvedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// =============================================================================
// USAGE TRACKING (Phase 1.8B)
// =============================================================================

enum UsageMetric {
  APPLICATIONS
  USERS
  STORAGE_GB
  EVENTS
  SESSIONS
  DEMONSTRATIONS
  REPLAYS
  REPORTS
  EXPORTS
  API_CALLS
}

model UsageRecord {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  organizationId String
  applicationId  String?
  environmentId  String?
  metric         UsageMetric
  value          Float
  limit          Float?       // Plan limit (null = unlimited)
  periodStart    DateTime
  periodEnd      DateTime
  recordedAt     DateTime     @default(now())

  @@index([organizationId, metric, periodStart])
  @@index([organizationId, applicationId, environmentId, metric])
}

model UsageSnapshot {
  id             String      @id @default(uuid())
  organizationId String
  applicationId  String?
  environmentId  String?
  metric         UsageMetric
  value          Float
  snapshotDate   DateTime    @default(now())

  @@index([organizationId, snapshotDate])
  @@index([organizationId, applicationId, environmentId])
}

// =============================================================================
// BILLING (Phase 1.8C)
// =============================================================================

model Invoice {
  id                     String          @id @default(uuid())
  organizationId         String
  invoiceNumber          String          @unique
  planType               PlanType
  billingInterval        BillingInterval
  currency               BillingCurrency
  subtotal               Int             // In smallest unit (cents/kobo)
  tax                    Int             @default(0)
  total                  Int
  status                 String          @default("PENDING") // PENDING, PAID, FAILED, REFUNDED
  provider               String?
  providerReference      String?
  providerCustomerId     String?
  providerSubscriptionId String?
  stripeInvoiceId        String?
  paystackRef            String?
  periodStart            DateTime
  periodEnd              DateTime
  paidAt                 DateTime?
  createdAt              DateTime        @default(now())
  paymentEvents          PaymentEvent[]

  @@index([organizationId, createdAt])
  @@index([provider, providerSubscriptionId])
  @@unique([provider, providerReference])
}

model PaymentEvent {
  id               String   @id @default(uuid())
  organizationId   String
  provider         String   // "STRIPE" | "PAYSTACK"
  eventType        String   // "checkout.completed", "invoice.paid", etc.
  providerEventId  String?
  providerReference String?
  invoiceId        String?
  invoice          Invoice? @relation(fields: [invoiceId], references: [id])
  payload          Json
  processingStatus String   @default("PROCESSED")
  processingError  String?
  receivedAt       DateTime @default(now())
  processedAt      DateTime?

  @@index([organizationId, processedAt])
  @@index([invoiceId])
  @@index([provider, providerReference])
  @@unique([provider, providerEventId])
}

model ApiKey {
  id              String      @id @default(uuid())
  environmentId   String
  environment     Environment @relation(fields: [environmentId], references: [id])
  /// SHA-256 hex digest of the raw key — never store plaintext
  keyHash         String      @unique
  /// First 8 hex chars prefixed with "sots_" for safe display (e.g. sots_a1b2c3d4)
  keyPrefix       String
  label           String?
  createdAt       DateTime    @default(now())
  lastUsedAt      DateTime?
  revokedAt       DateTime?
  expiresAt       DateTime?   // Explicit expiry for rotation policies
  createdByUserId String?     // Audit: which user generated this key
}

model Application {
  id             String        @id @default(uuid())
  name           String
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  environments      Environment[]
  onboardingProgress ApplicationOnboardingProgress?

  sessions          Session[]
  states            State[]
  transitions       Transition[]
  candidateStates   CandidateState[]
  missingStates     MissingState[]
  missingFlows      MissingFlow[]
  coverageSnapshots CoverageSnapshot[]
  workflows         Workflow[]
  demonstrations    Demonstration[]
  profile           ApplicationProfile?

  // FDRS relations (Section 22)
  behaviorGraphs         BehaviorGraph[]
  compiledRulesets       CompiledRuleset[]
  reconciliationReports  ReconciliationReport[]
  observedSnapshots      ObservedGraphSnapshot[]
  promotionDecisions     PromotionDecision[]
  recommendationEvidence RecommendationEvidence[]
  intentNormalizations   IntentNormalizationEntry[]
}

model ApplicationProfile {
  id            String      @id @default(uuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id])
  profileType   String
  createdAt     DateTime    @default(now())
}

model Session {
  id            String            @id // matches sessionId
  applicationId String
  application   Application       @relation(fields: [applicationId], references: [id])
  environmentId String?
  environment   Environment?      @relation(fields: [environmentId], references: [id])
  tenantId      String
  startTime     DateTime
  endTime       DateTime
  events        SessionEvent[]
  statistics    SessionStatistic?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model SessionEvent {
  id           String   @id @default(uuid())
  sessionId    String
  session      Session  @relation(fields: [sessionId], references: [id])
  eventType    String
  eventVersion String
  source       String
  timestamp    DateTime
  metadata     Json
  createdAt    DateTime @default(now())
}

model SessionStatistic {
  id         String  @id @default(uuid())
  sessionId  String  @unique
  session    Session @relation(fields: [sessionId], references: [id])
  eventCount Int
  errorCount Int
  durationMs Int
}

model State {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  name          String
  category      String?
  visitCount    Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  transitionsFrom Transition[]       @relation("FromState")
  transitionsTo   Transition[]       @relation("ToState")
  observations    StateObservation[]
}

model Transition {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  fromStateId   String
  fromState     State       @relation("FromState", fields: [fromStateId], references: [id])
  toStateId     String
  toState       State       @relation("ToState", fields: [toStateId], references: [id])
  action        String?
  frequency     Int         @default(1)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  observations TransitionObservation[]
}

model StateObservation {
  id        String   @id @default(uuid())
  stateId   String
  state     State    @relation(fields: [stateId], references: [id])
  sessionId String
  eventId   String
  timestamp DateTime
}

model TransitionObservation {
  id           String     @id @default(uuid())
  transitionId String
  transition   Transition @relation(fields: [transitionId], references: [id])
  sessionId    String
  fromEventId  String
  toEventId    String
  timestamp    DateTime
}

model CandidateState {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  stateName     String
  reason        String
  approved      Boolean     @default(false)
  createdAt     DateTime    @default(now())
}

model MissingState {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  stateName     String
  sourceState   String
  ruleName      String
  severity      String?
  confidence    Float       @default(1.0)
  reason        String?
  detectedAt    DateTime    @default(now())
}

model CoverageSnapshot {
  id                 String      @id @default(uuid())
  applicationId      String
  application        Application @relation(fields: [applicationId], references: [id])
  environmentId      String?
  environment        Environment? @relation(fields: [environmentId], references: [id])
  createdAt          DateTime    @default(now())
  observedStates     Int
  candidateStates    Int
  approvedStates     Int
  coveragePercent    Float
  transitionCoverage Float       @default(0)
  flowCoverage       Float       @default(0)
}

model MissingFlow {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  sourceFlow    Json
  suggestedFlow Json
  reason        String
  severity      String?
  confidence    Float       @default(1.0)
  createdAt     DateTime    @default(now())
}

model Workflow {
  id              String      @id @default(uuid())
  applicationId   String
  application     Application @relation(fields: [applicationId], references: [id])
  name            String
  path            Json
  stateCount      Int
  transitionCount Int
  executionCount  Int         @default(1)
  createdAt       DateTime    @default(now())
}

model Demonstration {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  environmentId String?
  environment   Environment? @relation(fields: [environmentId], references: [id])
  sessionId     String
  reportId      String?
  startedAt     DateTime    @default(now())
  completedAt   DateTime?
}

// =============================================================================
// FDRS — Flow Declaration & Reconciliation System (Section 22)
// Refactored to Polymorphic Behavior Knowledge Graphs (Phase 1.75)
// =============================================================================

enum GraphType {
  DECLARED
  DEMONSTRATED
  PRODUCTION
}

enum GraphSourceType {
  USER_DECLARATION
  DEMONSTRATION_SESSION
  PRODUCTION_OBSERVATION
  SYSTEM_GENERATED
}

enum FlowStatus {
  DRAFT
  COMPLETE
}

enum StateCategory {
  NAVIGATION
  UI
  BUSINESS
  ERROR
  SYSTEM
}

enum StateProvenance {
  USER_AUTHORED
  SUGGESTED_ACCEPTED
  DEMONSTRATION_PROMOTED
  TELEMETRY_OBSERVED
}

enum NormalizationScope {
  GLOBAL
  ORGANIZATION
  APPLICATION
}

enum GraphRelationshipType {
  DECLARES
  DERIVED_FROM
  PROMOTED_FROM
  BASELINE_OF
  COMPARED_TO
}

model BehaviorGraph {
  id            String          @id @default(uuid())
  applicationId String
  application   Application     @relation(fields: [applicationId], references: [id])
  environmentId String?
  environment   Environment?    @relation(fields: [environmentId], references: [id])
  isActive      Boolean         @default(true)  // Only one active version per app/env at a time
  name          String
  status        FlowStatus      @default(DRAFT)
  version       Int             @default(1)
  graphType     GraphType       @default(DECLARED)
  sourceType    GraphSourceType @default(USER_DECLARATION)
  declaredById  String?
  workflowType  String          @default("CUSTOM")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  completedAt   DateTime?

  nodes           BehaviorGraphNode[]
  edges           BehaviorGraphEdge[]
  rulesets        CompiledRuleset[]
  reconciliations ReconciliationReport[]
  versions        BehaviorGraphVersion[]

  @@index([applicationId, environmentId, isActive])
}

model BehaviorGraphNode {
  id                String                  @id @default(uuid())
  graphId           String
  graph             BehaviorGraph           @relation(fields: [graphId], references: [id])
  stateName         String
  behaviorKey       String?                 // Stable semantic identity
  category          StateCategory           @default(BUSINESS)
  provenance        StateProvenance         @default(USER_AUTHORED)
  declaredById      String?
  canonicalBehavior String?
  createdAt         DateTime                @default(now())

  suggestions     DeclaredStateSuggestion[]
  edgesFrom       BehaviorGraphEdge[]       @relation("FromNode")
  edgesTo         BehaviorGraphEdge[]       @relation("ToNode")
}

model BehaviorGraphEdge {
  id          String          @id @default(uuid())
  graphId     String
  graph       BehaviorGraph   @relation(fields: [graphId], references: [id])
  fromNodeId  String
  fromNode    BehaviorGraphNode @relation("FromNode", fields: [fromNodeId], references: [id])
  toNodeId    String
  toNode      BehaviorGraphNode @relation("ToNode", fields: [toNodeId], references: [id])
  action      String?
  provenance  StateProvenance   @default(USER_AUTHORED)
  createdAt   DateTime        @default(now())
}

model DeclaredStateSuggestion {
  id                       String             @id @default(uuid())
  parentStateId            String?
  parentState              BehaviorGraphNode? @relation(fields: [parentStateId], references: [id])
  organizationId           String?
  applicationId            String?
  flowId                   String?
  suggestionType           SuggestionType?
  title                    String?
  description              String?
  suggestedStateName       String
  category                 String
  severity                 RuleSeverity       @default(INFO)
  sourceTier               String
  rationale                String
  suggestedStatesJson      Json?
  suggestedTransitionsJson Json?
  evidenceJson             Json?
  source                   SuggestionSource   @default(RULE_ENGINE)
  confidence               Float
  status                   String             @default("PENDING")
  patternId                String?
  rulesetVersionIds        String[]           @default([])
  rulePatternIds           String[]           @default([])
  aiInvocationId           String?
  acceptedBy               String?
  acceptedAt               DateTime?
  rejectedBy               String?
  rejectedAt               DateTime?
  createdAt                DateTime           @default(now())

  outcomes SuggestionOutcome[]

  @@index([organizationId, applicationId])
  @@index([flowId])
  @@index([status])
  @@index([suggestionType])
}

model CompiledRuleset {
  id            String        @id @default(uuid())
  flowId        String        // Map flowId to BehaviorGraph.id
  flow          BehaviorGraph @relation(fields: [flowId], references: [id])
  applicationId String
  application   Application   @relation(fields: [applicationId], references: [id])
  version       Int
  compiledAt    DateTime      @default(now())
  rules         Json
  ruleCount     Int

  @@unique([flowId, version])
}

model ReconciliationReport {
  id            String        @id @default(uuid())
  flowId        String        // Map flowId to BehaviorGraph.id
  flow          BehaviorGraph @relation(fields: [flowId], references: [id])
  applicationId String
  application   Application   @relation(fields: [applicationId], references: [id])
  environmentId String?
  environment   Environment?  @relation(fields: [environmentId], references: [id])

  confirmedCount        Int
  trueGapCount          Int
  undeclaredCount       Int
  expectedCoverageScore Float
  trueGaps              Json
  undeclared            Json

  confirmedTransitions      Int   @default(0)
  trueGapTransitions        Int   @default(0)
  undeclaredTransitions     Int   @default(0)
  transitionCoverageScore   Float @default(0)
  trueGapTransitionsList    Json  @default("[]")
  undeclaredTransitionsList Json  @default("[]")

  generatedAt DateTime @default(now())
}

model BehaviorGraphVersion {
  id                         String        @id @default(uuid())
  graphId                    String
  graph                      BehaviorGraph @relation(fields: [graphId], references: [id])
  version                    Int
  snapshot                   Json
  isBaseline                 Boolean       @default(false)
  expectedStateCount         Int?
  expectedTransitionCount    Int?
  expectedCoverage           Float?
  expectedTransitionCoverage Float?
  createdAt                  DateTime      @default(now())

  @@unique([graphId, version])
}

model GraphRelationship {
  id               String                @id @default(uuid())
  sourceGraphId    String
  targetGraphId    String
  relationshipType GraphRelationshipType
  createdAt        DateTime              @default(now())
}

model PatternLibraryEntry {
  id                 String  @id @default(uuid())
  patternId          String  @unique
  triggerCanonicals  String
  triggerCategory    String
  suggestedStateName String
  category           String
  confidence         Float
  rationale          String
  libraryVersion     String
  active             Boolean @default(true)

  outcomes           SuggestionOutcome[]
  patternObservations PatternObservation[]
}

model IntentNormalizationEntry {
  id             String             @id @default(uuid())
  rawName        String
  canonical      String
  scope          NormalizationScope @default(GLOBAL)
  applicationId  String?
  application    Application?       @relation(fields: [applicationId], references: [id])
  organizationId String?
  organization   Organization?      @relation(fields: [organizationId], references: [id])
  libraryVersion String

  @@unique([scope, rawName, applicationId, organizationId])
}

model SuggestionOutcome {
  id              String                  @id @default(uuid())
  suggestionId    String
  suggestion      DeclaredStateSuggestion @relation(fields: [suggestionId], references: [id])
  patternId       String
  pattern         PatternLibraryEntry     @relation(fields: [patternId], references: [patternId])
  applicationId   String
  outcome         String
  rejectionReason String?
  recordedAt      DateTime                @default(now())
}

model ObservedGraphSnapshot {
  id              String      @id @default(uuid())
  applicationId   String
  application     Application @relation(fields: [applicationId], references: [id])
  environmentId   String?
  environment     Environment? @relation(fields: [environmentId], references: [id])
  snapshot        Json
  stateCount      Int
  transitionCount Int
  capturedAt      DateTime    @default(now())
}

model PromotionDecision {
  id            String      @id @default(uuid())
  stateName     String
  flowId        String
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  accepted      Boolean
  reason        String?
  decidedById   String?
  timestamp     DateTime    @default(now())
}

model PatternObservation {
  id             String              @id @default(uuid())
  patternId      String
  pattern        PatternLibraryEntry @relation(fields: [patternId], references: [patternId])
  applicationId  String
  sourceBehavior String
  targetBehavior String
  occurrences    Int                 @default(1)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([applicationId, patternId, sourceBehavior, targetBehavior])
}

model RecommendationEvidence {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  workflowId    String?
  evidenceType  String
  source        String
  confidence    Float
  payload       Json
  createdAt     DateTime    @default(now())
}

enum EnvironmentType {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

model Environment {
  id            String          @id @default(uuid())
  applicationId String
  application   Application     @relation(fields: [applicationId], references: [id])
  name          String          // e.g. "Development", "Staging", "Production"
  type          EnvironmentType @default(DEVELOPMENT)
  isDefault     Boolean         @default(false)
  sdkEnabled    Boolean         @default(true)

  apiKeys              ApiKey[]
  sessions             Session[]
  behaviorGraphs       BehaviorGraph[]
  coverageSnapshots    CoverageSnapshot[]
  observedSnapshots    ObservedGraphSnapshot[]
  demonstrations       Demonstration[]
  reconciliationReports ReconciliationReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([applicationId, name])
}

model ApplicationOnboardingProgress {
  id                       String      @id @default(uuid())
  applicationId            String      @unique
  application              Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  organizationCreated      Boolean     @default(true)
  applicationCreated       Boolean     @default(true)
  templateSelected         Boolean     @default(false)
  expectedFlowsDefined     Boolean     @default(false)
  installationTestPassed   Boolean     @default(false)
  sdkConnected             Boolean     @default(false)
  demonstrationCompleted   Boolean     @default(false)
  firstReportGenerated     Boolean     @default(false)
  valueRealized            Boolean     @default(false)
  valueRealizedReason      String?
  completedAt              DateTime?
}

model ActivationEvent {
  id             String   @id @default(uuid())
  organizationId String
  applicationId  String?
  environmentId  String?
  eventName      String
  metadata       Json?
  occurredAt     DateTime @default(now())

  @@index([organizationId, eventName, occurredAt])
}

// =============================================================================
// IDENTITY (Phase 2A)
// =============================================================================

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum OtpPurpose {
  SIGNUP      // New user — OTP sent before User exists
  LOGIN       // Returning user OTP auth
  INVITE      // Accept org invitation
}

enum AuditAction {
  // ─── Identity & Auth ─────────────────────────────
  USER_CREATED
  LOGIN_SUCCESS
  LOGIN_FAILED
  OTP_SENT
  OTP_VERIFIED
  OTP_FAILED
  SESSION_REFRESHED
  SESSION_REVOKED
  LOGOUT
  MEMBER_INVITED
  MEMBER_JOINED
  MEMBER_REMOVED
  ROLE_CHANGED
  MFA_ENABLED
  MFA_DISABLED
  MFA_VERIFIED
  MFA_CHALLENGE_FAILED
  MFA_BACKUP_CODE_USED
  SSO_LOGIN_SUCCESS
  SSO_PROVIDER_CONFIGURED
  SSO_PROVIDER_REMOVED
  PASSWORD_SET
  PASSWORD_CHANGED
  PREFERRED_AUTH_CHANGED

  // ─── Ruleset Governance ───────────────────────────
  RULESET_VERSION_CREATED
  RULESET_VERSION_PROMOTED
  RULESET_VERSION_ARCHIVED
  RULE_CANDIDATE_APPROVED
  RULE_CANDIDATE_REJECTED
  RULE_PATTERN_CREATED
  RULE_PATTERN_UPDATED

  // ─── AI & Flow ────────────────────────────────────
  AI_DRAFT_CREATED
  AI_DRAFT_ACCEPTED
  AI_DRAFT_PARTIALLY_ACCEPTED
  AI_DRAFT_REJECTED
  AI_SUGGESTION_ACCEPTED
  AI_SUGGESTION_REJECTED
  FLOW_CREATED
  FLOW_UPDATED
  FLOW_DELETED
  FLOW_COMPLETED

  // ─── API Keys ─────────────────────────────────────
  API_KEY_CREATED
  API_KEY_REVOKED
  API_KEY_ROTATED

  // ─── Billing ──────────────────────────────────────
  SUBSCRIPTION_ACTIVATED
  SUBSCRIPTION_CANCELLED
  SUBSCRIPTION_PAST_DUE
  PLAN_CHANGED
  INVOICE_PAID
  INVOICE_FAILED

  // ─── Reports & Exports ────────────────────────────
  REPORT_GENERATED
  REPORT_EXPORTED

  // ─── Feature Flags ────────────────────────────────
  ORG_FEATURE_FLAG_CHANGED

  // ─── Admin RBAC ───────────────────────────────────
  SYSTEM_ADMIN_GRANTED
  SYSTEM_ADMIN_REVOKED
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  displayName       String?
  avatarUrl         String?
  passwordHash      String?
  preferredAuthMode String    @default("OTP")
  passwordUpdatedAt DateTime?

  // ─── Gap 5: TOTP / MFA ──────────────────────────────────────────────────
  // totpSecret is stored AES-256 encrypted using MFA_ENCRYPTION_KEY.
  totpEnabled       Boolean   @default(false)
  totpSecret        String?   // AES-256-GCM encrypted — never store plaintext
  totpEnabledAt     DateTime?
  totpBackupCodes   String[]  @default([]) // bcrypt-hashed 8-char backup codes

  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessions                UserSession[]
  memberships             OrganizationMembership[]
  auditLogs               AuditLog[]
  notificationPreferences NotificationPreference[]
  emailDeliveries         EmailDelivery[]
  digestPreference        NotificationDigestPreference?
}

model OtpCode {
  id          String     @id @default(uuid())
  email       String
  codeHash    String     // sha256(plaintext_code)
  purpose     OtpPurpose
  expiresAt   DateTime
  usedAt      DateTime?
  ipAddress   String?
  createdAt   DateTime   @default(now())

  @@index([email, purpose])
}

model UserSession {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash  String    @unique  // sha256(plaintext_refresh_token)
  userAgent         String?
  ipAddress         String?
  expiresAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())

  @@index([userId])
}

model OrganizationMembership {
  id              String       @id @default(uuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role            MemberRole   @default(MEMBER)
  invitedByUserId String?
  joinedAt        DateTime     @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model OrganizationInvitation {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email           String
  role            MemberRole   @default(MEMBER)
  tokenHash       String       @unique  // sha256(invitation_token)
  createdByUserId String
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime     @default(now())

  @@index([organizationId])
  @@index([email])
}

model AuditLog {
  id             String      @id @default(uuid())
  userId         String?
  user           User?       @relation(fields: [userId], references: [id])
  organizationId String?
  action         AuditAction
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  createdAt      DateTime    @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([action])
  @@index([createdAt])
}

// =============================================================================
// NOTIFICATIONS & EMAIL (MVP)
// =============================================================================

enum EmailCategory {
  SECURITY
  ACCOUNT
  ONBOARDING
  REPORTS
  ALERTS
  BILLING
  TEAM
  DIGEST
  PRODUCT_EDUCATION
  COMPLIANCE
}

enum NotificationFrequency {
  IMMEDIATE
  DAILY_DIGEST
  WEEKLY_DIGEST
  NEVER
}

enum NotificationEventStatus {
  CREATED
  PROCESSING
  SENT
  FAILED
  SKIPPED
}

enum EmailDeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  FAILED
  SKIPPED
  SUPPRESSED
}

enum EmailProvider {
  RESEND
  CONSOLE
}

model EmailTemplate {
  id                String        @id @default(uuid())
  key               String        @unique
  category          EmailCategory
  subject           String
  preheader         String
  htmlPath          String
  textPath          String
  requiredVariables String[]
  defaultFrom       String
  version           Int           @default(1)
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model NotificationPreference {
  id             String                @id @default(uuid())
  userId         String
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       EmailCategory
  emailEnabled   Boolean               @default(true)
  inAppEnabled   Boolean               @default(true)
  webhookEnabled Boolean               @default(false)
  frequency      NotificationFrequency @default(IMMEDIATE)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([userId, organizationId, category])
  @@index([organizationId, category])
}

model NotificationEvent {
  id             String                  @id @default(uuid())
  organizationId String?
  organization   Organization?           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  applicationId  String?
  eventType      String
  severity       String                  @default("INFO")
  payload        Json
  status         NotificationEventStatus @default(CREATED)
  createdAt      DateTime                @default(now())
  deliveries     EmailDelivery[]

  @@index([organizationId, eventType, createdAt])
  @@index([applicationId, eventType, createdAt])
}

model EmailDelivery {
  id                  String              @id @default(uuid())
  notificationEventId String?
  notificationEvent   NotificationEvent?  @relation(fields: [notificationEventId], references: [id], onDelete: SetNull)
  userId              String?
  user                User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  toEmail             String
  templateKey         String
  provider            EmailProvider       @default(RESEND)
  providerMessageId   String?
  idempotencyKey      String?             @unique
  status              EmailDeliveryStatus @default(QUEUED)
  error               String?
  sentAt              DateTime?
  deliveredAt         DateTime?
  openedAt            DateTime?
  clickedAt           DateTime?
  bouncedAt           DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([toEmail, createdAt])
  @@index([providerMessageId])
  @@index([notificationEventId])
}

model EmailSuppression {
  id        String         @id @default(uuid())
  email     String
  reason    String
  category  EmailCategory?
  createdAt DateTime       @default(now())

  @@unique([email, category])
  @@index([email])
}

// =============================================================================
// FEATURE FLAGS (Organization-level)
// =============================================================================

model OrganizationFeatureFlag {
  id             String   @id @default(uuid())
  organizationId String
  key            String
  enabled        Boolean  @default(false)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
}

// =============================================================================
// AI USAGE AGGREGATES (Phase 1 — Metrics Persistence)
// =============================================================================

model AIUsageDailyAggregate {
  id              String    @id @default(uuid())
  organizationId  String?   // null = platform-wide aggregate
  applicationId   String?
  date            DateTime  // Truncated to UTC midnight (day boundary)
  feature         AIFeature
  provider        String
  model           String

  totalCalls      Int       @default(0)
  successCalls    Int       @default(0)
  failedCalls     Int       @default(0)
  repairedCalls   Int       @default(0)
  fallbackCalls   Int       @default(0)
  timeoutCalls    Int       @default(0)

  totalInputTokens  Int     @default(0)
  totalOutputTokens Int     @default(0)
  totalTokens       Int     @default(0)
  totalCostUsd      Decimal @default(0) @db.Decimal(14, 6)

  avgLatencyMs    Int       @default(0)
  p95LatencyMs    Int       @default(0)
  maxLatencyMs    Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([date, feature, provider, model, organizationId, applicationId])
  @@index([date, feature])
  @@index([organizationId, date])
  @@index([provider, model, date])
}

// =============================================================================
// SYSTEM ADMIN (DB-backed RBAC — replaces SYSTEM_ADMIN_USER_IDS env var)
// =============================================================================

enum SystemAdminScope {
  FULL            // All admin capabilities
  RULESETS_ONLY   // Can only manage rulesets and rule candidates
  READ_ONLY       // Can only read admin data (audit logs, AI usage)
}

model SystemAdmin {
  id             String           @id @default(uuid())
  userId         String           @unique
  scope          SystemAdminScope @default(FULL)
  grantedBy      String?          // userId of granter (null = seeded)
  grantedAt      DateTime         @default(now())
  revokedAt      DateTime?        // null = still active
  notes          String?          // Reason for grant

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([userId])
  @@index([revokedAt])
}

// =============================================================================
// GAP 4 — CROSS-TENANT PATTERN INDEX
// Anonymized, aggregated state patterns contributed by opted-in organizations.
// =============================================================================

model CrossTenantPatternIndex {
  id                String   @id @default(cuid())
  patternKey        String   // canonical state name, e.g. "CHECKOUT_FAILURE"
  domain            String   // "ecommerce", "lms", "generic"
  /// Anonymized example — contains only { stateName, category, transitionCount }
  /// Never stores organizationId or applicationId.
  anonymizedExample Json
  occurrenceCount   Int      @default(1)
  /// 0.0–1.0: computed as min(occurrenceCount / 50, 1.0)
  confidenceScore   Float
  /// Array of { suggestedStateName, category, rationale } branch-state suggestions
  suggestedBranches Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([patternKey, domain])
  @@index([domain])
  @@index([confidenceScore])
}

// =============================================================================
// GAP 5 — MFA CHALLENGE TOKEN
// Short-lived (5 min) challenge issued after first-factor verification when
// the user has TOTP enabled. Replaced by full session tokens on /auth/mfa/verify.
// =============================================================================

model MfaChallengeToken {
  id          String   @id @default(uuid())
  userId      String
  tokenHash   String   @unique // sha256(raw_challenge_token)
  expiresAt   DateTime
  usedAt      DateTime?
  attempts    Int      @default(0)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

// =============================================================================
// GAP 6 — SSO / OIDC PROVIDER
// One OIDC provider config per organization. The clientSecret field is
// AES-256-GCM encrypted using OIDC_CLIENT_SECRET_KEY env var.
// =============================================================================

model OIDCProvider {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  displayName    String       // Shown on the login button, e.g. "Acme Corp SSO"
  issuerUrl      String       // OIDC discovery base, e.g. https://login.microsoftonline.com/{tenant}/v2.0
  clientId       String
  /// AES-256-GCM encrypted client secret — never store plaintext
  clientSecret   String
  scopes         String[]     @default(["openid", "email", "profile"])
  isActive       Boolean      @default(true)
  /// Email domains that must use this SSO provider, e.g. ["acme.com", "acme.co.uk"]
  allowedDomains String[]     @default([])

  /// Optional: preset name for UI hints. One of: "microsoft", "okta", "google", "custom"
  providerPreset String?      @default("custom")

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([allowedDomains])
}

// =============================================================================
// GAP 7 — NOTIFICATION DIGEST PREFERENCES
// Per-user digest configuration for batch email workers.
// A separate model from NotificationPreference (which is per org/category).
// =============================================================================

enum DigestFrequency {
  DAILY
  WEEKLY
  NEVER
}

model NotificationDigestPreference {
  id                  String           @id @default(uuid())
  userId              String           @unique
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  weeklyReport        Boolean          @default(true)
  coverageAlerts      Boolean          @default(true)
  // Only relevant for SystemAdmin users
  ruleCandidateAlerts Boolean          @default(false)

  digestFrequency     DigestFrequency  @default(WEEKLY)
  lastWeeklyReportAt  DateTime?
  lastCoverageAlertAt DateTime?

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}
